{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES6",
    "declaration": true,
    "outDir": "./dist",
    "lib": [
      "es2017"
    ],
    "moduleResolution": "node",
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules"
  ],
  "ts-node": {
    "compilerOptions": {
      "module": "commonjs"
    }
  }
}